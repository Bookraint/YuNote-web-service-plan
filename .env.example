# ─────────────────────────────────────────────────────────────
#  YuNote Web 服务环境变量配置
#  复制本文件为 .env，填入真实值后启动服务：
#      cp .env.example .env
#      python run_web.py
# ─────────────────────────────────────────────────────────────

# ── LLM（OpenAI 兼容接口，当前对应 DashScope Qwen） ───────────
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-plus

# ── ElevenLabs 转录 ──────────────────────────────────────────
# 桌面：设置 → 「转录引擎」分组（选 ElevenLabs 时显示下列项）；settings.json → [ElevenLabs]
# Web 当前走 allow_unauthenticated，一般无需填 API Key
ELEVENLABS_MODEL_ID=scribe_v1          # 桌面卡片「ElevenLabs 模型 ID」；json: ModelId
ELEVENLABS_DIARIZE=true                # 桌面开关「ElevenLabs 说话人分离」；json: Diarize
ELEVENLABS_TAG_AUDIO_EVENTS=false      # 桌面开关「标记非语音事件」；json: TagAudioEvents

# ── 转录参数（长音频分块 / 限流）──────────────────────────────
# 桌面：设置 → 「转录引擎」→「转录语言」；json: Transcribe.TranscribeLanguage（桌面写「自动检测」等，此处用 API 语言码）
# 留空 = 自动检测；可填 zh / en / ja / ko / yue …
TRANSCRIBE_LANGUAGE=
# 以下 5 项：桌面同一分组里点「并发与分块（长音频）」打开弹窗「并发与分块」；json: Transcribe.*
TRANSCRIBE_CHUNK_LENGTH_MINUTES=15     # 弹窗「每块时长（分钟）」；json: ChunkLengthMinutes
TRANSCRIBE_SPLIT_THRESHOLD_MINUTES=25  # 弹窗「长文件自动切分阈值（分钟）」；json: SplitThresholdMinutes
TRANSCRIBE_RATE_LIMIT_PER_MINUTE=10    # 弹窗「API 速率限制」（每分钟请求数）；json: ApiRateLimitPerMinute
TRANSCRIBE_MAX_CONCURRENT_CHUNKS=3     # 弹窗「最大并发片段数」；json: MaxConcurrentChunks
TRANSCRIBE_CHUNK_MAX_RETRIES=3        # 弹窗「失败重试次数」；json: ChunkMaxRetries
# 注：桌面另有弹窗开关「启用异步并发处理」，Web 端固定为异步分块，无对应环境变量

# ── 总结参数（Map-Reduce 长文总结）────────────────────────────
# 桌面：设置 → 「AI 总结」分组；settings.json → Summary.*
SUMMARY_CHUNK_SIZE=4093               # 卡片「分块大小」；json: ChunkSize
SUMMARY_MAP_CONCURRENCY=5               # 卡片「总结 Map 并发数」；json: MapConcurrency
SUMMARY_MAP_RPM=30                    # 卡片「总结 Map API 限速 (RPM)」；json: MapRpm

# 场景 Prompt 模板目录（默认本项目 prompts/；见 prompts/README.md）
# PROMPTS_DIR=

# ── 存储路径（相对路径自动创建；可改为绝对路径）──────────────
# NOTES_DIR=./data/notes
# UPLOAD_DIR=./data/uploads
# DB_PATH=./data/jobs.db

# ── 服务器 ───────────────────────────────────────────────────
MAX_UPLOAD_MB=500
# 生产环境改为你的前端域名，如 https://example.com
CORS_ORIGINS=*
