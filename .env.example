# ─────────────────────────────────────────────────────────────
#  YuNote Web 服务环境变量配置（无需用户账号，一次付款即用）
#  复制本文件为 .env，填入真实值后启动服务：
#      cp .env.example .env
#      python run_web.py
# ─────────────────────────────────────────────────────────────

# ── Supabase（数据库）────────────────────────────────────────
# 在 Supabase 控制台 Settings → API 中查看
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Stripe 支付（可选）──────────────────────────────────────
# 默认关闭：不设或 false = 免支付，确认订单后直接跑任务（本地 / 未接 Stripe 时用）
# 上线收款时：设为 true，并填入 Dashboard 里的真实 sk_test_… / sk_live_…（非占位符）
STRIPE_CHECKOUT_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── 服务基础 URL（Stripe 回跳地址用）────────────────────────
# 本地开发：http://localhost:7860
# 生产（HF Space）：https://dfsfads-yunote.hf.space
BASE_URL=http://localhost:7860

# ── 计费定价（分/分钟）──────────────────────────────────────
PRICE_PER_MIN_STANDARD_CENTS=50
PRICE_PER_MIN_PREMIUM_CENTS=150

# ── LLM（OpenAI 兼容接口）────────────────────────────────────
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-plus
LLM_MODEL_PREMIUM=qwen-max
# 单次总结请求超时（秒），默认 600；卡住过久可调大或检查 API
LLM_REQUEST_TIMEOUT_SEC=600

# ── ElevenLabs 转录 ──────────────────────────────────────────
ELEVENLABS_MODEL_ID=scribe_v1
ELEVENLABS_DIARIZE=true
ELEVENLABS_TAG_AUDIO_EVENTS=false

# ── 转录参数 ─────────────────────────────────────────────────
TRANSCRIBE_LANGUAGE=
TRANSCRIBE_CHUNK_LENGTH_MINUTES=15
TRANSCRIBE_SPLIT_THRESHOLD_MINUTES=25
TRANSCRIBE_RATE_LIMIT_PER_MINUTE=10
TRANSCRIBE_MAX_CONCURRENT_CHUNKS=3
TRANSCRIBE_CHUNK_MAX_RETRIES=3

# ── 总结参数 ─────────────────────────────────────────────────
SUMMARY_CHUNK_SIZE=4093
SUMMARY_MAP_CONCURRENCY=5
SUMMARY_MAP_RPM=30

# ── 存储路径 ─────────────────────────────────────────────────
# NOTES_DIR=./data/notes
# UPLOAD_DIR=./data/uploads

# ── 服务器 ───────────────────────────────────────────────────
MAX_UPLOAD_MB=500
CORS_ORIGINS=*
