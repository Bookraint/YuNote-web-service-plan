# ─────────────────────────────────────────────────────────────
#  YuNote Web 服务环境变量配置
#  复制本文件为 .env，填入真实值后启动服务：
#      cp .env.example .env
#      python run_web.py
# ─────────────────────────────────────────────────────────────

# ── LLM（OpenAI 兼容接口，当前对应 DashScope Qwen） ───────────
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-plus

# ── ElevenLabs 转录 ──────────────────────────────────────────
# 无需 API Key（使用 allow_unauthenticated），如需官方认证改为官方请求头
ELEVENLABS_MODEL_ID=scribe_v1
ELEVENLABS_DIARIZE=true
ELEVENLABS_TAG_AUDIO_EVENTS=false

# ── 转录参数（对应 YuNote 桌面端 settings.json Transcribe 段）──
# TRANSCRIBE_LANGUAGE 留空 = 自动检测；需要指定时填: zh / en / ja / ko / yue ...
TRANSCRIBE_LANGUAGE=
TRANSCRIBE_CHUNK_LENGTH_MINUTES=15
TRANSCRIBE_SPLIT_THRESHOLD_MINUTES=25
TRANSCRIBE_RATE_LIMIT_PER_MINUTE=10
TRANSCRIBE_MAX_CONCURRENT_CHUNKS=3
TRANSCRIBE_CHUNK_MAX_RETRIES=3

# ── 总结参数（长文分块与 API 限流）──────────────────────────────
SUMMARY_CHUNK_SIZE=4093
SUMMARY_MAP_CONCURRENCY=5
SUMMARY_MAP_RPM=30

# 场景 Prompt 模板目录（默认本项目 prompts/；见 prompts/README.md）
# PROMPTS_DIR=

# ── 存储路径（相对路径自动创建；可改为绝对路径）──────────────
# NOTES_DIR=./data/notes
# UPLOAD_DIR=./data/uploads
# DB_PATH=./data/jobs.db

# ── 服务器 ───────────────────────────────────────────────────
MAX_UPLOAD_MB=500
# 生产环境改为你的前端域名，如 https://example.com
CORS_ORIGINS=*
