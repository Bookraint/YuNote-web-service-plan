# ─────────────────────────────────────────────────────────────
#  YuNote Web 服务环境变量配置（兑换码积分制，无用户账号）
#  复制本文件为 .env，填入真实值后启动服务：
#      cp .env.example .env
#      python run_web.py
# ─────────────────────────────────────────────────────────────

# ── Supabase（数据库）────────────────────────────────────────
# 在 Supabase 控制台 Settings → API 中查看
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── 兑换码积分定价（积分/分钟）────────────────────────────
# 标准档：每分钟消耗 10 积分；高级档：每分钟消耗 30 积分
# 兑换码面值在 redeem_codes 表中配置（由管理员写入）
PRICE_PER_MIN_STANDARD_CREDITS=10
PRICE_PER_MIN_PREMIUM_CREDITS=30

# ── 开发/测试模式（本地调试用）────────────────────────────
# 设为 true 时，任意输入的兑换码均视为有效，跳过数据库验证
DEV_SKIP_REDEEM=false

# ── 管理后台密钥 ────────────────────────────────────────
# 用于 POST /api/admin/codes 生成兑换码接口（Header: X-Admin-Key）
# 请设置为足够随机的长字符串，不要泄露！
ADMIN_KEY=your-strong-random-admin-key-here

# ── LLM（OpenAI 兼容接口）────────────────────────────────────
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-plus
LLM_MODEL_PREMIUM=qwen-max
# 单次总结请求超时（秒），默认 600；卡住过久可调大或检查 API
LLM_REQUEST_TIMEOUT_SEC=600

# ── ElevenLabs 转录 ──────────────────────────────────────────
ELEVENLABS_MODEL_ID=scribe_v1
ELEVENLABS_DIARIZE=true
ELEVENLABS_TAG_AUDIO_EVENTS=false

# ── 转录参数 ─────────────────────────────────────────────────
TRANSCRIBE_LANGUAGE=
TRANSCRIBE_CHUNK_LENGTH_MINUTES=15
TRANSCRIBE_SPLIT_THRESHOLD_MINUTES=25
TRANSCRIBE_RATE_LIMIT_PER_MINUTE=10
TRANSCRIBE_MAX_CONCURRENT_CHUNKS=3
TRANSCRIBE_CHUNK_MAX_RETRIES=3

# ── 总结参数 ─────────────────────────────────────────────────
SUMMARY_CHUNK_SIZE=4093
SUMMARY_MAP_CONCURRENCY=5
SUMMARY_MAP_RPM=30

# ── 存储路径 ─────────────────────────────────────────────────
# NOTES_DIR=./data/notes
# UPLOAD_DIR=./data/uploads

# ── 服务器 ───────────────────────────────────────────────────
MAX_UPLOAD_MB=500
CORS_ORIGINS=*

# ── 并发控制 ─────────────────────────────────────────────────
# 同时运行的 pipeline 线程数上限（超出任务排队等待空位后自动开始）。
# HF Space 资源有限建议设 2；本地调试可设 4 或更高。
MAX_CONCURRENT_JOBS=2
